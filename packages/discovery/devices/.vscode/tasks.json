{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "Discovery Devices",
         "type": "shell",
         "group": "build",
         "presentation": {
            "echo": true,
            "reveal": "always",
            "focus": false,
            "panel": "shared",
            "showReuseMessage": true,
            "clear": true
         },
         "command": ". /home/${env:USER}/.bashrc;ssh ${env:USER}@${env:BUILD_SERVER} '. .profile;cd ${env:REMOTE_SRCDIR}/www; npx nx build discovery-devices; cd ${env:REMOTE_SRCDIR}/www/dist/packages/discovery-devices;pwd;scp -r *  statseeker@${env:TEST_SERVER}:${env:SSROOT}/www'",
         "dependsOn": ["Sync to build server"]
      }
   ]
}

{
   "name": "discovery-main",
   "$schema": "../../../node_modules/nx/schemas/project-schema.json",
   "projectType": "application",
   "sourceRoot": "packages/discovery/main/src",
   "tags": [],
   "targets": {
      "build": {
         "executor": "@nx/vite:build",
         "options": {
            "outputPath": "dist/packages/discovery-main",
            "deleteOutputPath": true,
            "tsConfig": "packages/discovery/main/tsconfig.app.json"
         }
      },
      "lint": {
         "executor": "nx:run-commands",
         "outputs": ["{options.outputFile}"],
         "options": {
            "command": "eslint . --quiet",
            "cwd": "packages/discovery/main/src",
            "lintFilePatterns": ["packages/discovery/main/**/*.{ts,tsx,js,jsx}"]
         }
      }
   }
}

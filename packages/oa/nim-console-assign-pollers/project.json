{
   "name": "oa-nim-console-assign-pollers",
   "$schema": "../../../node_modules/nx/schemas/project-schema.json",
   "projectType": "application",
   "sourceRoot": "packages/oa/nim-console-assign-pollers/src",
   "tags": ["oa"],
   "targets": {
      "build": {
         "executor": "@nx/vite:build",
         "options": {
            "outputPath": "dist/packages/oa-nim-console-assign-pollers",
            "deleteOutputPath": true,
            "tsConfig": "packages/oa/nim-console-assign-pollers/tsconfig.app.json"
         }
      },
      "lint": {
         "executor": "nx:run-commands",
         "outputs": ["{options.outputFile}"],
         "options": {
            "command": "eslint . --quiet",
            "cwd": "packages/oa/nim-console-assign-pollers",
            "lintFilePatterns": ["packages/oa/nim-console-assign-pollers/**/*.{ts,tsx,js,jsx}"]
         }
      }
   }
}

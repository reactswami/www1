{
   "extends": "./tsconfig.json",
   "compilerOptions": {
      "outDir": "../../../dist/out-tsc",
      "types": ["node", "@nx/react/typings/cssmodule.d.ts", "@nx/react/typings/image.d.ts"],
      "lib": ["DOM.Iterable", "DOM"],
      "allowJs": true,
      "paths": {
         "@statseeker": ["libraries"],
         "@statseeker/api": ["libraries/api/src"],
         "@statseeker/api/*": ["libraries/api/src/*"],
         "@statseeker/components": ["libraries/components/src"],
         "@statseeker/components/*": ["libraries/components/src/*"],
         "@statseeker/hooks": ["libraries/hooks/src"],
         "@statseeker/hooks/*": ["libraries/hooks/src/*"],
         "@statseeker/ui": ["libraries/ui/src"],
         "@statseeker/ui/*": ["libraries/ui/src/*"],
         "@statseeker/utils": ["libraries/utils/src"],
         "@statseeker/utils/*": ["libraries/utils/src/*"],
         "@tooling/configuration": ["libraries/tooling/configuration/src"],
         "~/api": ["packages/oa/image-downloader/src/api"],
         "~/api/*": ["packages/oa/image-downloader/src/api/*"],
         "~/components": ["packages/oa/image-downloader/src/components"],
         "~/components/*": ["packages/oa/image-downloader/src/components/*"],
         "~/config": ["packages/oa/image-downloader/src/config"],
         "~/config/*": ["packages/oa/image-downloader/src/config/*"],
         "~/contexts": ["packages/oa/image-downloader/src/contexts"],
         "~/contexts/*": ["packages/oa/image-downloader/src/contexts/*"],
         "~/features": ["packages/oa/image-downloader/src/features"],
         "~/features/*": ["packages/oa/image-downloader/src/features/*"],
         "~/hooks": ["packages/oa/image-downloader/src/hooks"],
         "~/hooks/*": ["packages/oa/image-downloader/src/hooks/*"],
         "~/lib": ["packages/oa/image-downloader/src/lib"],
         "~/lib/*": ["packages/oa/image-downloader/src/lib/*"],
         "~/providers": ["packages/oa/image-downloader/src/providers"],
         "~/providers/*": ["packages/oa/image-downloader/src/providers/*"],
         "~/reducers": ["packages/oa/image-downloader/src/reducers"],
         "~/reducers/*": ["packages/oa/image-downloader/src/reducers/*"],
         "~/routes": ["packages/oa/image-downloader/src/routes"],
         "~/routes/*": ["packages/oa/image-downloader/src/routes/*"],
         "~/test": ["packages/oa/image-downloader/src/test"],
         "~/test/*": ["packages/oa/image-downloader/src/test/*"],
         "~/types": ["packages/oa/image-downloader/src/types"],
         "~/types/*": ["packages/oa/image-downloader/src/types/*"],
         "~/utils": ["packages/oa/image-downloader/src/utils"],
         "~/utils/*": ["packages/oa/image-downloader/src/utils/*"]
      }
   },
   "exclude": [
      "**/*.spec.ts",
      "**/*.test.ts",
      "vite.config.ts",
      "vite.config.mts",
      "vitest.config.ts",
      "vitest.config.mts",
      "src/**/*.test.ts",
      "src/**/*.spec.ts",
      "src/**/*.test.tsx",
      "src/**/*.spec.tsx",
      "src/**/*.test.js",
      "src/**/*.spec.js",
      "src/**/*.test.jsx",
      "src/**/*.spec.jsx",
      "src/test-setup.ts",
      "src/test-setup.ts"
   ],
   "include": ["src/**/*.ts"]
}
